{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user financial profile and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "monthlyIncome": { "type": "number" },
        "monthlyExpenses": { "type": "number" },
        "savingsCapacity": { "type": "number" },
        "investmentGoal": { "type": "string", "enum": ["short-term", "long-term"] },
        "preferredLanguage": { "type": "string", "enum": ["hinglish", "english"] },
        "onboardingCompleted": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "onboardingCompleted"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the chat history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sender", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat messages for a specific user"
    }
  }
}
